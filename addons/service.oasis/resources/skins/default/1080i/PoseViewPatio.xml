<?xml version="1.0" encoding="UTF-8"?>
<window>
	<controls>
		<control type="panel">
			<itemlayout width="960" height="540">
				<control type="cameraview">
					<description>Camera view</description>
					<topic>$INFO[ListItem.Property(smarthome.cameratopic)]</topic>
					<stretchmode>zoom</stretchmode>
				</control>
				<control type="image">
					<description>Label background</description>
					<bottom>-20</bottom>
					<height>90</height>
					<left>-20</left>
					<right>-20</right>
					<texture border="40">buttons/dialogbutton-nofo.png</texture>
				</control>
				<control type="label">
					<description>Camera label</description>
					<bottom>0</bottom>
					<height>50</height>
					<label>$INFO[ListItem.Label]</label>
					<font>font37</font>
					<align>center</align>
					<aligny>center</aligny>
					<textcolor>white</textcolor>
					<shadowcolor>black</shadowcolor>
				</control>
			</itemlayout>
			<focusedlayout width="960" height="540">
				<control type="cameraview">
					<description>Camera view</description>
					<topic>$INFO[ListItem.Property(smarthome.cameratopic)]</topic>
					<stretchmode>zoom</stretchmode>
				</control>
				<control type="image">
					<description>Label background</description>
					<bottom>-20</bottom>
					<height>90</height>
					<left>-20</left>
					<right>-20</right>
					<texture border="40">buttons/dialogbutton-nofo.png</texture>
				</control>
				<control type="label">
					<description>Camera label</description>
					<bottom>0</bottom>
					<height>50</height>
					<label>$INFO[ListItem.Label]</label>
					<font>font37</font>
					<align>center</align>
					<aligny>center</aligny>
					<textcolor>white</textcolor>
					<shadowcolor>black</shadowcolor>
				</control>
			</focusedlayout>
			<content>
				<item>
					<label>Bar AI</label>
					<property name="smarthome.cameratopic">/oasis/bar/pose_image</property>
				</item>
				<item>
					<label>Hallway AI</label>
					<property name="smarthome.cameratopic">/oasis/kinect2/pose_image</property>
				</item>
				<item>
					<label>Kitchen AI</label>
					<property name="smarthome.cameratopic">/oasis/kitchen/pose_image</property>
				</item>
				<item>
					<label>Doorway AI</label>
					<property name="smarthome.cameratopic">/oasis/station/pose_image</property>
				</item>
			</content>
		</control>
	</controls>
</window>
