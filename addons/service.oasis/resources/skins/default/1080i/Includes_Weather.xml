<?xml version="1.0" encoding="UTF-8"?>
<includes>
    <include name="OasisWeatherIconMyWeather">
        <control type="group">
            <description>Horizontal weather icons with a label below</description>
            <width>240</width>
            <control type="image">
                <height>80</height>
                <texture colordiffuse="D0FFFFFF">$PARAM[texture]</texture>
                <aspectratio>keep</aspectratio>
            </control>
            <control type="textbox">
                <top>90</top>
                <height>110</height>
                <left>20</left>
                <right>20</right>
                <font>font37_narrow</font>
                <align>center</align>
                <aligny>center</aligny>
                <label>$INFO[$PARAM[label]]</label>
                <shadowcolor>text_shadow</shadowcolor>
            </control>
        </control>
    </include>

    <include name="OasisWeatherWidget">
        <control type="panel">
            <description>Weather widget with a horizontal scrollable list of items</description>
            <height>300</height>
            <orientation>horizontal</orientation>
            <scrolltime tween="cubic" easing="out">500</scrolltime>
            <itemlayout width="$PARAM[item_width]" height="500">
                <control type="group">
                    <control type="label">
                        <align>center</align>
                        <font>font37_narrow</font>
                        <label>$INFO[ListItem.Label]</label>
                        <shadowcolor>text_shadow</shadowcolor>
                    </control>
                    <control type="multiimage">
                        <top>45</top>
                        <height>128</height>
                        <imagepath>$INFO[ListItem.Icon]</imagepath>
                        <aspectratio>keep</aspectratio>
                        <timeperimage>20</timeperimage>
                        <fadetime>10</fadetime>
                        <randomize>false</randomize>
                    </control>
                    <control type="label">
                        <top>168</top>
                        <align>center</align>
                        <font>font25_title</font>
                        <label>$INFO[ListItem.Label2]</label>
                        <shadowcolor>text_shadow</shadowcolor>
                    </control>
                </control>
            </itemlayout>
            <focusedlayout width="$PARAM[item_width]" height="500">
                <control type="group">
                    <control type="label">
                        <align>center</align>
                        <font>font37_narrow</font>
                        <label>$INFO[ListItem.Label]</label>
                        <shadowcolor>text_shadow</shadowcolor>
                    </control>
                    <control type="multiimage">
                        <top>45</top>
                        <height>128</height>
                        <imagepath>$INFO[ListItem.Icon]</imagepath>
                        <aspectratio>keep</aspectratio>
                        <timeperimage>20</timeperimage>
                        <fadetime>10</fadetime>
                        <randomize>false</randomize>
                    </control>
                    <control type="label">
                        <top>168</top>
                        <align>center</align>
                        <font>font32_narrow</font>
                        <label>$INFO[ListItem.Label2]</label>
                        <shadowcolor>text_shadow</shadowcolor>
                    </control>
                </control>
            </focusedlayout>
            <include>$PARAM[content_include]</include>
        </control>
    </include>

    <include name="OasisDailyItems">
        <content>
            <include content="WeatherDailyItem">
                <param name="item_index" value="1" />
            </include>
            <include content="WeatherDailyItem">
                <param name="item_index" value="2" />
            </include>
            <include content="WeatherDailyItem">
                <param name="item_index" value="3" />
            </include>
            <include content="WeatherDailyItem">
                <param name="item_index" value="4" />
            </include>
            <include content="WeatherDailyItem">
                <param name="item_index" value="5" />
            </include>
            <include content="WeatherDailyItem">
                <param name="item_index" value="6" />
            </include>
            <include content="WeatherDailyItem">
                <param name="item_index" value="7" />
            </include>
            <include content="WeatherDailyItem">
                <param name="item_index" value="8" />
            </include>
        </content>
    </include>

