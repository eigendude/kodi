            <property name="smarthome.cameratopic1">/oasis/falcon/image_rect</property>
            <property name="smarthome.cameratopic2">/oasis/falcon/flow</property>
            <property name="smarthome.cameratopic3">/oasis/falcon/pose_image</property>
        </item>
