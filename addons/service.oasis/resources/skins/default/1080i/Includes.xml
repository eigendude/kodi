    <include name="OasisWeatherWidget">
        <param name="width">266</param>
        <param name="list_id">0</param>
        <param name="visible">true</param>
        <param name="content_include" />
        <definition>
            <control type="group">
                <visible>$PARAM[visible]</visible>
                <control type="panel" id="$PARAM[list_id]">
                    <left>0</left>
                    <top>90</top>
                    <right>0</right>
                    <height>396</height>
                    <orientation>horizontal</orientation>
                    <scrolltime tween="cubic" easing="out">500</scrolltime>
                    <preloaditems>2</preloaditems>
                    <itemlayout width="$PARAM[width]" height="320">
                        <control type="group">
                            <control type="multiimage">
                                <left>60</left>
                                <top>108</top>
                                <width>130</width>
                                <height>130</height>
                                <imagepath>$INFO[ListItem.Icon]</imagepath>
                                <aspectratio>keep</aspectratio>
                                <timeperimage>20</timeperimage>
                                <fadetime>10</fadetime>
                                <randomize>false</randomize>
                            </control>
                            <control type="label">
                                <left>15</left>
                                <top>45</top>
                                <align>center</align>
                                <width>230</width>
                                <label>$INFO[ListItem.Label]</label>
                                <shadowcolor>text_shadow</shadowcolor>
                            </control>
                            <control type="label">
                                <left>15</left>
                                <top>236</top>
                                <align>center</align>
                                <width>230</width>
                                <font>font12</font>
                                <label>$INFO[ListItem.Label2]</label>
                                <shadowcolor>text_shadow</shadowcolor>
                            </control>
                        </control>
                    </itemlayout>
                    <focusedlayout width="$PARAM[width]" height="320">
                        <control type="group">
                            <control type="multiimage">
                                <left>60</left>
                                <top>108</top>
                                <width>130</width>
                                <height>130</height>
                                <imagepath>$INFO[ListItem.Icon]</imagepath>
                                <aspectratio>keep</aspectratio>
                                <timeperimage>20</timeperimage>
                                <fadetime>10</fadetime>
                                <randomize>false</randomize>
                            </control>
                            <control type="label">
                                <left>15</left>
                                <top>45</top>
                                <align>center</align>
                                <width>230</width>
                                <label>$INFO[ListItem.Label]</label>
                                <shadowcolor>text_shadow</shadowcolor>
                            </control>
                            <control type="label">
                                <left>15</left>
                                <top>236</top>
                                <align>center</align>
                                <width>230</width>
                                <font>font12</font>
                                <label>$INFO[ListItem.Label2]</label>
                                <shadowcolor>text_shadow</shadowcolor>
                            </control>
                        </control>
                    </focusedlayout>
                    <content>
                        <include>$PARAM[content_include]</include>
                    </content>
                </control>
            </control>
        </definition>
    </include>
