<?xml version="1.0" encoding="UTF-8"?>
<window>
	<controls>
		<control type="videowindow">
			<description>Video background</description>
		</control>
		<control type="group">
			<description>Station content area</description>
			<visible>SmartHome.HasStation</visible>
			<animation effect="fade" time="1500">VisibleChange</animation>
			<left>130</left>
			<width>860</width>
			<top>100</top>
			<height>880</height>
			<control type="image">
				<description>Station content area background</description>
				<top>-20</top>
				<bottom>-20</bottom>
				<left>-20</left>
				<right>-20</right>
				<texture border="40">buttons/dialogbutton-nofo.png</texture>
			</control>
			<control type="list">
				<description>Sensor data list</description>
				<orientation>vertical</orientation>
				<itemlayout width="860" height="140">
					<control type="label">
						<label>$INFO[ListItem.Label]</label>
						<left>30</left>
						<font>font52_title</font>
						<shadowcolor>text_shadow</shadowcolor>
						<align>left</align>
						<aligny>center</aligny>
					</control>
					<control type="label">
						<label>$INFO[ListItem.Label2]</label>
						<right>30</right>
						<font>font52_title</font>
						<shadowcolor>text_shadow</shadowcolor>
						<align>right</align>
						<aligny>center</aligny>
					</control>
				</itemlayout>
				<focusedlayout width="860" height="140">
					<control type="label">
						<label>$INFO[ListItem.Label]</label>
						<left>30</left>
						<font>font52_title</font>
						<shadowcolor>text_shadow</shadowcolor>
						<align>left</align>
						<aligny>center</aligny>
					</control>
					<control type="label">
						<label>$INFO[ListItem.Label2]</label>
						<right>30</right>
						<font>font52_title</font>
						<shadowcolor>text_shadow</shadowcolor>
						<align>right</align>
						<aligny>center</aligny>
					</control>
				</focusedlayout>
				<content>
					<item>
						<label>CPU Utilization</label>
						<label2>$INFO[SmartHome.System(station).CPUUtilization]</label2> <!-- 20 % -->
					</item>
					<item>
						<label>CPU Temperature</label>
						<label2>$INFO[SmartHome.System(station).CPUTemperature]</label2> <!-- 120 °F -->
					</item>
					<item>
						<label>Supply</label>
						<label2>$INFO[SmartHome.StationSupply]</label2> <!--10.4 V-->
					</item>
					<item>
						<label>Motor</label>
						<label2>$INFO[SmartHome.StationMotor]</label2> <!--7.8 V-->
					</item>
					<item>
						<label>Current</label>
						<label2>$INFO[SmartHome.StationCurrent]</label2> <!--0.1 ?-->
					</item>
				</content>
			</control>
		</control>
	</controls>
</window>
