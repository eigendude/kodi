<?xml version="1.0" encoding="UTF-8"?>
<window>
	<controls>
		<control type="panel">
		<width>1152</width>
			<itemlayout width="384" height="180">
				<control type="cameraview">
					<topic>$INFO[ListItem.Property(smarthome.cameratopic)]</topic>
					<stretchmode>zoom</stretchmode>
				</control>
				<control type="image">
					<bottom>-20</bottom>
					<height>90</height>
					<left>-20</left>
					<right>-20</right>
					<texture border="40">buttons/dialogbutton-nofo.png</texture>
				</control>
				<control type="label">
					<bottom>0</bottom>
					<height>50</height>
					<label>$INFO[ListItem.Label]</label>
					<font>font25</font>
					<align>center</align>
					<aligny>center</aligny>
					<textcolor>white</textcolor>
					<shadowcolor>black</shadowcolor>
				</control>
				<control type="image">
					<bottom>50</bottom>
					<texture>$INFO[ListItem.Art(icon)]</texture>
					<aspectratio>keep</aspectratio>
				</control>
			</itemlayout>
			<focusedlayout width="384" height="180">
				<control type="cameraview">
					<topic>$INFO[ListItem.Property(smarthome.cameratopic)]</topic>
					<stretchmode>zoom</stretchmode>
				</control>
				<control type="image">
					<bottom>-20</bottom>
					<height>90</height>
					<left>-20</left>
					<right>-20</right>
					<texture border="40">buttons/dialogbutton-nofo.png</texture>
				</control>
				<control type="label">
					<bottom>0</bottom>
					<height>50</height>
					<label>$INFO[ListItem.Label]</label>
					<font>font25</font>
					<align>center</align>
					<aligny>center</aligny>
					<textcolor>white</textcolor>
					<shadowcolor>black</shadowcolor>
				</control>
				<control type="image">
					<bottom>50</bottom>
					<texture>$INFO[ListItem.Art(icon)]</texture>
					<aspectratio>keep</aspectratio>
				</control>
			</focusedlayout>
			<content>
				<item>
					<label>HD Color</label>
					<property name="smarthome.cameratopic">/oasis/kinect2/hd/image_color</property>
				</item>
				<item>
					<label>HD Color Rectified</label>
					<property name="smarthome.cameratopic">/oasis/kinect2/hd/image_color_rect</property>
				</item>
				<item>
					<label>HD Depth</label>
					<property name="smarthome.cameratopic">/oasis/kinect2/hd/image_depth</property>
				</item>
				<item>
					<label>HD Depth Rectified</label>
					<!-- TODO: Crashes Kinect2 driver
					<property name="smarthome.cameratopic">/oasis/kinect2/hd/image_depth_rect</property>
					-->
					<icon>DefaultAddonNone.png</icon>
				</item>
				<item>
					<label>HD Mono</label>
					<property name="smarthome.cameratopic">/oasis/kinect2/hd/image_mono</property>
				</item>
				<item>
					<label>HD Mono Rectified</label>
					<property name="smarthome.cameratopic">/oasis/kinect2/hd/image_mono_rect</property>
				</item>
				<item>
					<label>QHD Color</label>
					<property name="smarthome.cameratopic">/oasis/kinect2/qhd/image_color</property>
				</item>
				<item>
					<label>QHD Color Rectified</label>
					<property name="smarthome.cameratopic">/oasis/kinect2/qhd/image_color_rect</property>
				</item>
				<item>
					<label>QHD Depth</label>
					<property name="smarthome.cameratopic">/oasis/kinect2/qhd/image_depth</property>
				</item>
				<item>
					<label>QHD Depth Rectified</label>
					<!-- TODO: Crashes Kinect2 driver
					<property name="smarthome.cameratopic">/oasis/kinect2/qhd/image_depth_rect</property>
					-->
					<icon>DefaultAddonNone.png</icon>
				</item>
				<item>
					<label>QHD Mono</label>
					<property name="smarthome.cameratopic">/oasis/kinect2/qhd/image_mono</property>
				</item>
				<item>
					<label>QHD Mono Rectified</label>
					<property name="smarthome.cameratopic">/oasis/kinect2/qhd/image_mono_rect</property>
				</item>
				<item>
					<label>SD Color</label>
					<property name="smarthome.cameratopic">/oasis/kinect2/sd/image_color</property>
				</item>
				<item>
					<label>SD Color Rectified</label>
					<property name="smarthome.cameratopic">/oasis/kinect2/sd/image_color_rect</property>
				</item>
				<item>
					<label>SD Depth</label>
					<property name="smarthome.cameratopic">/oasis/kinect2/sd/image_depth</property>
				</item>
				<item>
					<label>SD Depth Rectified</label>
					<property name="smarthome.cameratopic">/oasis/kinect2/sd/image_depth_rect</property>
				</item>
				<item>
					<label>SD IR</label>
					<property name="smarthome.cameratopic">/oasis/kinect2/hd/image_ir</property>
				</item>
				<item>
					<label>SD IR Rectified</label>
					<property name="smarthome.cameratopic">/oasis/kinect2/hd/image_ir_rect</property>
				</item>
			</content>
		</control>
	</controls>
</window>
