<?xml version="1.0" encoding="UTF-8"?>
<includes>
    <include name="OasisTrainSystemTelemetryItem">
        <item>
            <label>$PARAM[label]</label>
            <property name="smarthome.isactive">$PARAM[isactive]</property>
            <property name="smarthome.cpuutilization">$PARAM[cpuutilization]</property>
            <property name="smarthome.cputemperature">$PARAM[cputemperature]</property>
            <property name="smarthome.ramutilization">$PARAM[ramutilization]</property>
            <property name="smarthome.ramtotal">$PARAM[ramtotal]</property>
        </item>
    </include>
    <include name="OasisTrainSystemListItem">
        <control type="label">
            <description>System name</description>
            <left>30</left>
            <label>$INFO[ListItem.Label]</label>
            <font>font_MainMenu</font>
            <shadowcolor>text_shadow</shadowcolor>
            <align>left</align>
            <aligny>center</aligny>
        </control>
        <control type="label">
            <description>CPU Usage</description>
            <right>1000</right>
            <label>$INFO[ListItem.Property(smarthome.cpuutilization)]</label>
            <font>font_MainMenu</font>
            <shadowcolor>text_shadow</shadowcolor>
            <align>right</align>
            <aligny>center</aligny>
            <visible>!String.IsEmpty(ListItem.Property(smarthome.isactive))</visible>
            <animation effect="fade" time="1500">VisibleChange</animation>
        </control>
        <control type="label">
            <description>CPU Temperature</description>
            <right>680</right>
            <label>$INFO[ListItem.Property(smarthome.cputemperature)]</label>
            <font>font_MainMenu</font>
            <shadowcolor>text_shadow</shadowcolor>
            <align>right</align>
            <aligny>center</aligny>
            <visible>!String.IsEmpty(ListItem.Property(smarthome.isactive))</visible>
            <animation effect="fade" time="1500">VisibleChange</animation>
        </control>
        <control type="label">
            <description>RAM Usage</description>
            <right>350</right>
            <label>$INFO[ListItem.Property(smarthome.ramutilization)]</label>
            <font>font_MainMenu</font>
            <shadowcolor>text_shadow</shadowcolor>
            <align>right</align>
            <aligny>center</aligny>
            <visible>!String.IsEmpty(ListItem.Property(smarthome.isactive))</visible>
            <animation effect="fade" time="1500">VisibleChange</animation>
        </control>
        <control type="label">
            <description>Total RAM</description>
            <right>30</right>
            <label>$INFO[ListItem.Property(smarthome.ramtotal)]</label>
            <font>font_MainMenu</font>
            <shadowcolor>text_shadow</shadowcolor>
            <align>right</align>
            <aligny>center</aligny>
        </control>
    </include>
    <include name="OasisTrainSystemContent">
        <item>
            <description>Dummy item with column headers</description>
            <property name="smarthome.isactive">true</property>
            <property name="smarthome.cpuutilization">CPU %</property>
            <property name="smarthome.cputemperature">CPU °F</property>
            <property name="smarthome.ramutilization">RAM %</property>
            <property name="smarthome.ramtotal">Total</property>
        </item>
        <include content="OasisTrainSystemTelemetryItem">
            <param name="label">Little Brain</param>
            <param name="isactive">$INFO[SmartHome.System(conductor).IsActive(1)]</param>
            <param name="ramutilization">$INFO[SmartHome.System(conductor).RAMUtilization]</param>
            <param name="ramtotal">2048 B</param>
        </include>
        <include content="OasisTrainSystemTelemetryItem">
            <param name="label">Big Brain</param>
            <param name="isactive">$INFO[SmartHome.System(station).IsActive(1)]</param>
            <param name="cpuutilization">$INFO[SmartHome.System(station).CPUUtilization]</param>
            <param name="cputemperature">$INFO[SmartHome.System(station).CPUTemperature]</param>
            <param name="ramutilization">$INFO[SmartHome.System(station).RAMUtilization]</param>
            <param name="ramtotal">8 GB</param>
        </include>
        <include content="OasisTrainSystemTelemetryItem">
            <param name="label">Mega Brain</param>
            <param name="isactive">$INFO[SmartHome.System(oceanplatform).IsActive(1)]</param>
            <param name="cpuutilization">$INFO[SmartHome.System(oceanplatform).CPUUtilization]</param>
            <param name="cputemperature">$INFO[SmartHome.System(oceanplatform).CPUTemperature]</param>
            <param name="ramutilization">$INFO[SmartHome.System(oceanplatform).RAMUtilization]</param>
            <param name="ramtotal">32 GB</param>
        </include>
    </include>
    <include name="OasisTrainSensorListItem">
        <control type="label">
            <left>30</left>
            <label>$INFO[ListItem.Label]</label>
			<animation effect="fade" time="1500">VisibleChange</animation>
            <visible>true</visible> <!-- TODO -->
            <font>WeatherTemp</font>
            <shadowcolor>text_shadow</shadowcolor>
            <align>left</align>
            <aligny>center</aligny>
        </control>
        <control type="label">
            <right>30</right>
            <label>$INFO[ListItem.Label2]</label>
            <font>WeatherTemp</font>
            <shadowcolor>text_shadow</shadowcolor>
            <align>right</align>
            <aligny>center</aligny>
            <visible>true</visible> <!-- TODO -->
            <animation effect="fade" time="1500">VisibleChange</animation>
        </control>
    </include>
    <include name="OasisTrainSensorContent">
        <item>
            <label>Supply</label>
            <label2>$INFO[SmartHome.StationSupply]</label2> <!-- 12.0 V -->
        </item>
        <item>
            <label>Motor</label>
            <label2>$INFO[SmartHome.StationMotor]</label2> <!-- 7.8 V -->
        </item>
        <item>
            <label>Current</label>
            <label2>$INFO[SmartHome.StationCurrent]</label2> <!-- 0.1 A -->
        </item>
    </include>
    <include name="OasisTrainCameraListItem">
        <control type="cameraview">
            <topic>$INFO[ListItem.Property(smarthome.cameratopic1)]</topic>
            <stretchmode>zoom</stretchmode>
            <width>34%</width>
        </control>
        <control type="cameraview">
            <topic>$INFO[ListItem.Property(smarthome.cameratopic2)]</topic>
            <stretchmode>zoom</stretchmode>
            <right>33%</right>
            <width>34%</width>
        </control>
        <control type="cameraview">
            <topic>$INFO[ListItem.Property(smarthome.cameratopic3)]</topic>
            <stretchmode>zoom</stretchmode>
            <right>0</right>
            <width>34%</width>
        </control>
    </include>
    <include name="OasisTrainCameraContent">
        <item>
            <label>Camera</label>
            <property name="smarthome.cameratopic1">/oasis/livingroom/image_rect</property>
            <property name="smarthome.cameratopic2">/oasis/livingroom/background</property>
            <property name="smarthome.cameratopic3">/oasis/livingroom/foreground</property>
        </item>
    </include>
</includes>
